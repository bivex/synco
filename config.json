{
  "version": "1.0",
  "description": "WebSocket time servers configuration for commpage_time_probe",
  "servers": [
    {
      "name": "Binance BTC/USDT Trade Stream",
      "url": "wss://stream.binance.com:9443/ws/btcusdt@trade",
      "type": "stream",
      "timestamp_field": "E",
      "timestamp_unit": "milliseconds",
      "description": "Binance cryptocurrency trade stream with event timestamps"
    },
    {
      "name": "Binance ETH/USDT Trade Stream",
      "url": "wss://stream.binance.com:9443/ws/ethusdt@trade",
      "type": "stream",
      "timestamp_field": "E",
      "timestamp_unit": "milliseconds",
      "description": "Binance Ethereum trade stream with event timestamps"
    },
    {
      "name": "Binance SOL/USDT Trade Stream",
      "url": "wss://stream.binance.com:9443/ws/solusdt@trade",
      "type": "stream",
      "timestamp_field": "E",
      "timestamp_unit": "milliseconds",
      "description": "Binance Solana trade stream with event timestamps"
    },
    {
      "name": "Binance BNB/USDT Trade Stream",
      "url": "wss://stream.binance.com:9443/ws/bnbusdt@trade",
      "type": "stream",
      "timestamp_field": "E",
      "timestamp_unit": "milliseconds",
      "description": "Binance BNB trade stream with event timestamps"
    },
    {
      "name": "Binance XRP/USDT Trade Stream",
