    },
    {
      "name": "Kraken SOL/USD Ticker",
      "url": "wss://ws.kraken.com/v2",
      "type": "request",
      "request_message": "{\"method\":\"subscribe\",\"params\":{\"channel\":\"ticker\",\"symbol\":[\"SOL/USD\"]}}",
      "timestamp_field": "timestamp",
      "timestamp_unit": "iso8601",
      "description": "Kraken v2 SOL/USD ticker feed"
