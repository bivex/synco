      "request_message": "{\"event\":\"subscribe\",\"channel\":\"trades\",\"symbol\":\"tBTCUSD\"}",
      "timestamp_field": "time",
      "timestamp_unit": "milliseconds",
      "description": "Bitfinex BTCUSD trades"
