  "notes": {
    "binance": "Binance streams use 'E' field for event time in milliseconds since Unix epoch. All stream URLs contain '@' character for automatic detection.",
    "coinbase": "Coinbase uses ISO8601 timestamps like '2024-03-07T12:34:56.789Z'. Requires subscription message.",
    "kraken": "Kraken v2 ticker uses nested data[0].timestamp in ISO8601 format.",
    "okx": "OKX uses 'ts' field in milliseconds. Requires v5 public channel subscription.",
    "bybit": "Bybit uses 'T' field for trade time in milliseconds. v5 public spot API.",
    "bitfinex": "Bitfinex uses 'time' in milliseconds. Uses channel symbol format like 'tBTCUSD'.",
    "bitstamp": "Bitstamp uses 'microtimestamp' - microseconds since epoch! Very high precision.",
    "latency": "Typical latency: 10-50ms (same region), 50-150ms (cross-region), 150-300ms (intercontinental).",
    "timestamp_fields": "Supported: 'E', 'T', 'ts', 'time', 'time_ms', 'microtimestamp', 'seconds', 'create_time', 'create_time_ms', 't', 'timestamp'. ISO8601 strings and ns/us/ms/sec numeric values are also parsed.",
    "environment_dependent": "Some endpoints depend on region/network policy. Binance US may time out outside supported environments.",
    "usage": "Use with commpage_time_probe: ./commpage_time_probe <url> [request_json]"
  }
