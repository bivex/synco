    {
      "name": "Binance BTC/USDT Ticker",
      "url": "wss://stream.binance.com:9443/ws/btcusdt@ticker",
      "type": "stream",
      "timestamp_field": "E",
      "timestamp_unit": "milliseconds",
      "description": "Binance BTC/USDT ticker with 24hr ticker statistics"
    },
    {
      "name": "Binance All Market Tickers Stream",
      "url": "wss://stream.binance.com:9443/ws/!ticker@arr",
      "type": "stream",
      "timestamp_field": "E",
      "timestamp_unit": "milliseconds",
      "description": "All market tickers stream (array of all symbols)"
    },
    {
      "name": "Coinbase BTC-USD Feed",
      "url": "wss://ws-feed.exchange.coinbase.com",
      "type": "request",
      "request_message": "{\"type\":\"subscribe\",\"product_ids\":[\"BTC-USD\"],\"channels\":[\"ticker\"]}",
      "timestamp_field": "time",
      "timestamp_unit": "iso8601",
      "description": "Coinbase Pro BTC-USD ticker feed"
    },
    {
      "name": "Coinbase ETH-USD Feed",
      "url": "wss://ws-feed.exchange.coinbase.com",
      "type": "request",
      "request_message": "{\"type\":\"subscribe\",\"product_ids\":[\"ETH-USD\"],\"channels\":[\"ticker\"]}",
      "timestamp_field": "time",
      "timestamp_unit": "iso8601",
      "description": "Coinbase Pro ETH-USD ticker feed"
    },
    {
      "name": "Coinbase SOL-USD Feed",
      "url": "wss://ws-feed.exchange.coinbase.com",
      "type": "request",
      "request_message": "{\"type\":\"subscribe\",\"product_ids\":[\"SOL-USD\"],\"channels\":[\"ticker\"]}",
      "timestamp_field": "time",
      "timestamp_unit": "iso8601",
      "description": "Coinbase SOL-USD ticker feed"
    },
    {
      "name": "Kraken BTC/USD Ticker",
      "url": "wss://ws.kraken.com/v2",
      "type": "request",
      "request_message": "{\"method\":\"subscribe\",\"params\":{\"channel\":\"ticker\",\"symbol\":[\"BTC/USD\"]}}",
      "timestamp_field": "timestamp",
      "timestamp_unit": "iso8601",
      "description": "Kraken v2 BTC/USD ticker"
    },
    {
      "name": "Kraken ETH/USD Ticker",
